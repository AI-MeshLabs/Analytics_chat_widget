SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_DB_SCHEMA=onepoint
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional RPC name (default: analytics_readonly_sql)
# SUPABASE_READONLY_SQL_RPC=analytics_readonly_sql
# One-time: run scripts/analytics_readonly_sql.sql in Supabase SQL editor

# Widget routing: false = n8n webhook (default), true = local /api/analytics-chat/query
NEXT_PUBLIC_WIDGET_USE_BACKEND=false
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-path

NODE_ENV=development
