SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_DB_SCHEMA=your-db-schema
# Required for n8n { "sql": "SELECT ..." } on /api/analytics-chat/query (encode % in password as %25)
# If VPS shows ENETUNREACH on port 5432, use Supabase Dashboard → Database → Connection pooler (port 6543) URI instead.
PROJECTDB_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-id.supabase.co:5432/postgres
# Optional fallback if PROJECTDB_URL is unset: SUPABASE_URL + SUPABASE_DB_PASSWORD
# SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
NODE_ENV=development

# Widget routing: true = local /api/analytics-chat/query, false = n8n webhook
NEXT_PUBLIC_WIDGET_USE_BACKEND=false

# Widget → n8n (browser-safe; used by public/analytics-widget.js via AnalyticsChatWidget)
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-path
NEXT_PUBLIC_WIDGET_SECRET=your-shared-widget-secret
