SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_DB_SCHEMA=onepoint
PROJECTDB_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-id.supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
NODE_ENV=production

# Widget routing: true = local /api/analytics-chat/query, false = n8n webhook
NEXT_PUBLIC_WIDGET_USE_BACKEND=true

# Widget → n8n (browser-safe; used by public/analytics-widget.js via AnalyticsChatWidget)
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-path
NEXT_PUBLIC_WIDGET_SECRET=your-shared-widget-secret
